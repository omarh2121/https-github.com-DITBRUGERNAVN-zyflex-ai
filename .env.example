# =============================================================================
# .env.example – Zyflex AI Environment Variables (EKSEMPEL)
#
# BRUG:
#   1. Kopiér denne fil til .env  →  cp .env.example .env
#   2. Udfyld de felter du har nøgler til
#   3. TILFØJ .env til .gitignore – del ALDRIG denne fil med rigtige nøgler
#
# MINIMUM for at køre systemet:
#   Ingen nøgler er strengt nødvendige – systemet har fallbacks for alt.
#   Open-Meteo er 100% gratis og kræver ingen nøgle.
# =============================================================================


# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000


# ── Billetto API (PRIMÆR event-kilde) ────────────────────────────────────────
# Danmarks bedste event-platform – stærk lokal dansk dækning
# Gratis Bearer token: Opret konto på https://billetto.dk og hent API-nøgle
# API docs: https://billetto.dk/api/v3/public/events
# Uden nøgle: systemet bruger lokale events.json + mock data
BILLETTO_API_KEY=


# ── Ticketmaster API (valgfri fallback) ──────────────────────────────────────
# Svag dansk dækning – kun fallback hvis Billetto fejler
# Gratis nøgle: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=


# ── Push-notifikationer via ntfy.sh (valgfri – gratis) ───────────────────────
# Format: vælg et unikt channel-navn
# Chaufføren abonnerer via app: https://ntfy.sh/<dit-channel>
NTFY_CHANNEL=zyflex-horsens-42x9


# ── Google OAuth (til SaaS-login) ─────────────────────────────────────────────
# Opret credentials: https://console.cloud.google.com/
# Redirect URI: https://DIN-DOMAIN.com/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── OpenAI (valgfri – til fremtidige LLM-agents) ─────────────────────────────
# Bruges IKKE i MVP – reserveret til fremtidig AI-ruting i DemandAgent
# Pris: ca. $0.001 pr. recommendation-kald med gpt-4o-mini
# OPENAI_API_KEY=


# ── Ngrok (valgfri – midlertidigt offentligt link under udvikling) ────────────
# Gratis konto: https://ngrok.com/
# OBS: Til produktion – brug Render.com eller Railway i stedet
NGROK_AUTH_TOKEN=


# ── Fremtidige integrationer ──────────────────────────────────────────────────

# DSB Rejseplanen API (togforsinkelser = ekstra taxi-behov)
# https://help.rejseplanen.dk/hc/da/articles/214174465
# DSB_API_KEY=

# Vejdirektoratet – vejarbejde og trafi-data
# https://www.vejdirektoratet.dk/api
# VEJDIR_API_KEY=

# Supabase (hvis du vil skifte fra JSON-filer til en rigtig database)
# SUPABASE_URL=
# SUPABASE_KEY=

# Render.com deployment (sættes automatisk af Render)
# RENDER_EXTERNAL_URL=


# ── LangGraph Pipeline Tuning (avanceret) ─────────────────────────────────────
# Hvor mange minutter cache-TTL for /ai/* endpoints (default: 5)
# AI_CACHE_TTL_MINUTES=5

# H3 resolution (6=~3km hex, 7=~1km hex, 8=~500m hex) – default: 8
# H3_RESOLUTION=8

# Radius i km for H3 heatmap generering – default: 6
# H3_RADIUS_KM=6
